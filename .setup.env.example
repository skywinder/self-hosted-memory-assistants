# Unified setup configuration for self-hosted-memory-assistants
# Copy to .setup.env and fill in the values you actually use.

# Shared admin account used where applicable
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# Shared external API keys
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
HF_TOKEN=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# -----------------------------------------------------------------------------
# Mycelia
# -----------------------------------------------------------------------------
MYCELIA_URL=https://localhost:4433
MYCELIA_FRONTEND_HOST=https://localhost:4433
MYCELIA_NGINX_PORT=4433
MYCELIA_MONGO_INITDB_ROOT_USERNAME=root
MYCELIA_MONGO_INITDB_ROOT_PASSWORD=password
MYCELIA_REDIS_PASSWORD=password

# -----------------------------------------------------------------------------
# Chronicle
# -----------------------------------------------------------------------------
CHRONICLE_DOMAIN=localhost
CHRONICLE_DEPLOYMENT_MODE=docker-compose
CHRONICLE_OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Ushadow
# -----------------------------------------------------------------------------
USHADOW_ENV_NAME=ushadow
USHADOW_PORT_OFFSET=10
USHADOW_DEV_MODE=true
USHADOW_HOST_IP=localhost
USHADOW_POSTGRES_USER=ushadow
USHADOW_POSTGRES_PASSWORD=ushadow
USHADOW_POSTGRES_DB=ushadow
USHADOW_POSTGRES_MULTIPLE_DATABASES=metamcp,openmemory
USHADOW_NEO4J_USERNAME=neo4j
USHADOW_NEO4J_PASSWORD=password
USHADOW_KC_REALM=ushadow
USHADOW_KC_FRONTEND_CLIENT_ID=ushadow-frontend
USHADOW_KC_BACKEND_CLIENT_ID=ushadow-backend
USHADOW_KC_CLIENT_SECRET=
USHADOW_KC_BOOTSTRAP_ADMIN_USERNAME=admin
USHADOW_KC_BOOTSTRAP_ADMIN_PASSWORD=admin
USHADOW_KC_PORT=8081
USHADOW_KC_MGMT_PORT=9000
USHADOW_KC_HOSTNAME_URL=http://localhost:8081
USHADOW_KC_MOBILE_URL=

